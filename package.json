{
  "name": "@wyre-technology/abnormal-mcp",
  "version": "1.0.0",
  "description": "MCP server for Abnormal Security — AI-powered threat detection, case management, and email remediation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "abnormal-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:mcpb": "mcpb pack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/abnormal-mcp.git"
  },
  "keywords": [
    "mcp",
    "claude",
    "abnormal",
    "abnormal-security",
    "security",
    "threat-detection",
    "email-security",
    "msp"
  ],
  "author": "Wyre Technology",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/wyre-technology/abnormal-mcp/issues"
  },
  "homepage": "https://github.com/wyre-technology/abnormal-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "semantic-release": "^25.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
